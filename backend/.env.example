# ============================================================
# SAMARTH PROPERTIES — Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
FRONTEND_URL=https://your-site.netlify.app

# ── SUPABASE ─────────────────────────────────────────────────
# Get from: supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── JWT AUTHENTICATION ───────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret_here
JWT_ADMIN_EXPIRY=8h
JWT_CONFIG_EXPIRY=4h

# ── SECRET URL PATHS ─────────────────────────────────────────
ADMIN_PANEL_PATH=your-secret-admin-path
CONFIG_PANEL_PATH=your-secret-config-path

# ── EMAIL (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password_here
ADMIN_NOTIFICATION_EMAIL=your-email@gmail.com

# ── MEDIA PROCESSING ─────────────────────────────────────────
MAX_FILE_SIZE_MB=50
IMAGE_QUALITY=85
THUMBNAIL_WIDTH=400
THUMBNAIL_HEIGHT=300
LARGE_IMAGE_WIDTH=1920
LARGE_IMAGE_HEIGHT=1080
WEBP_QUALITY=80

# ── RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5

# ── CORS ─────────────────────────────────────────────────────
# Add your Netlify URL here after deploying
ALLOWED_ORIGINS=https://your-site.netlify.app

# ── WHATSAPP ─────────────────────────────────────────────────
# Number with country code, no + or spaces: 919876543210
WHATSAPP_NUMBER=919373076213
